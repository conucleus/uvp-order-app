{
  "name": "@uvp-eth/order-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "vite",
    "dev:demo": "VITE_UVP_ORDER_APP_DEMO=1 vite",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "tsx --test src/**/*.test.ts",
    "test:full-mode-gate": "tsx --test src/testing/orderAppFullModeGate.test.ts",
    "test:e2e": "playwright test e2e/order-app.smoke.spec.ts e2e/evidence-proof.spec.ts",
    "test:e2e:api-stub": "UVP_ORDER_APP_E2E_PROFILE=api-stub UVP_ORDER_APP_E2E_PORT=4184 playwright test e2e/order-app.readiness.spec.ts",
    "test:e2e:fail-closed": "UVP_ORDER_APP_E2E_PROFILE=fail-closed UVP_ORDER_APP_E2E_PORT=4186 playwright test e2e/order-app.fail-closed.spec.ts",
    "test:e2e:full": "UVP_ORDER_APP_E2E_PROFILE=full playwright test e2e/order-app.full.spec.ts --project=chromium",
    "test:e2e:mobile": "UVP_ORDER_APP_E2E_PROFILE=api-stub UVP_ORDER_APP_E2E_MOBILE=1 UVP_ORDER_APP_E2E_PORT=4185 playwright test e2e/order-app.mobile.spec.ts --project=mobile-smoke",
    "test:e2e:readiness": "pnpm test:e2e:api-stub && pnpm test:e2e:mobile && pnpm test:e2e:fail-closed",
    "readiness": "pnpm typecheck && pnpm build && pnpm test && pnpm test:e2e && pnpm test:e2e:readiness"
  },
  "dependencies": {
    "@uvp-eth/executor-kit": "workspace:*",
    "@uvp-eth/product-dto": "workspace:*",
    "lucide-react": "^1.7.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.13.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vite": "^6.2.0"
  }
}
